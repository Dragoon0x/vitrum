{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "vitrum",
  "homepage": "https://vitrum.dev",
  "items": [
    {
      "name": "theme",
      "type": "registry:theme",
      "title": "Vitrum Theme",
      "description": "Material tokens, the glass surface system, and motion primitives. Every Vitrum component depends on this stylesheet.",
      "files": [
        {
          "path": "registry/vitrum/theme/vitrum.css",
          "type": "registry:file",
          "target": "~/vitrum.css"
        }
      ],
      "docs": "Import the stylesheet once in your global CSS (after `@import \"tailwindcss\"`): `@import \"../vitrum.css\";` \u2014 adjust the relative path to where your globals live."
    },
    {
      "name": "glass",
      "type": "registry:ui",
      "title": "Glass",
      "description": "The material primitive: refractive glass surfaces with engine detection, geometry-exact displacement baking, shared filter definitions, and pointer sheen.",
      "dependencies": [
        "radix-ui"
      ],
      "registryDependencies": [
        "https://vitrum.dev/r/theme.json",
        "utils"
      ],
      "files": [
        {
          "path": "registry/vitrum/ui/glass.tsx",
          "type": "registry:ui"
        },
        {
          "path": "registry/vitrum/ui/glass-root.tsx",
          "type": "registry:ui"
        },
        {
          "path": "registry/vitrum/ui/glass-defs.tsx",
          "type": "registry:ui"
        },
        {
          "path": "registry/vitrum/ui/glass-watcher.tsx",
          "type": "registry:ui"
        },
        {
          "path": "registry/vitrum/lib/glass-filter.ts",
          "type": "registry:lib"
        },
        {
          "path": "registry/vitrum/lib/glass-engine.ts",
          "type": "registry:lib"
        },
        {
          "path": "registry/vitrum/lib/glass-optics.ts",
          "type": "registry:lib"
        },
        {
          "path": "registry/vitrum/lib/optics-manager.ts",
          "type": "registry:lib"
        },
        {
          "path": "registry/vitrum/hooks/use-sheen.ts",
          "type": "registry:hook"
        },
        {
          "path": "registry/vitrum/hooks/use-glass-engine.ts",
          "type": "registry:hook"
        }
      ],
      "docs": "Render <GlassRoot/> once at the top of <body> to enable refraction. Without it, surfaces render in the frost engine."
    },
